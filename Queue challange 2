#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int nums[200];
    for(int i=0;i<n;i++){
        scanf("%d",&nums[i]);
    }
    for(int i=0;i<n;i++){
        int found=0;
        for(int j=1;j<n;j++){
            int q=(i+j)%n;
            if(nums[q]>nums[i]){
                printf("%d ",nums[q]);
                found=1;
                break;
            }
        }
        if(found==0){
            printf("-1 ");
        }
    }
    return 0;
}
