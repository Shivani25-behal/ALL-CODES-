#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>
int precedence(char op) {
    switch (op) {
        case '+':
        case '-':
            return 1;
        case '*':
        case '/':
            return 2;
        case '^':
            return 3;
        default:
            return 0;
    }
}
char* convertInfixToPostfix(char* infixExp) {
    int len = strlen(infixExp);
    int top = -1, x = 0;
    char* postfix = (char*)malloc(len + 1);
    char stack[100];   
    for (int i = 0; i < len; i++) {
        char ch = infixExp[i];
        if (isalnum(ch)) {
            postfix[x++] = ch;
        }
        else if (ch == '+' || ch == '-' || ch == '*' || ch == '/' || ch == '^') {
            while (top != -1 &&
                   precedence(ch) <= precedence(stack[top]) &&
                   ch != '^') {
                postfix[x++] = stack[top--];
            }
            stack[++top] = ch;
        }
        else if (ch == '(') {
            stack[++top] = ch;
        }
        else if (ch == ')') {
            while (top != -1 && stack[top] != '(') {
                postfix[x++] = stack[top--];
            }
            if (top != -1)
                top--;   
        }
    }
    while (top != -1) {
        postfix[x++] = stack[top--];
    }
    postfix[x] = '\0';
    return postfix;
}
int main() {
    char infixExp[100];
    scanf("%s", infixExp);
    char* postfixExp = convertInfixToPostfix(infixExp);
    printf("%s\n", postfixExp);
    free(postfixExp);
    return 0;
}
