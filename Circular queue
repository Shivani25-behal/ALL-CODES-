#include<stdio.h>
#define MAX 100
int queue[MAX],front=-1,rear=-1;

int isFull(){
    if((rear + 1) % MAX == front) {
        return 1;
    }
    return 0;
}

int isEmpty(){
    return front == -1;
}

void enqueue(int data){
    if(isFull()){
        printf("Overflow error\n");
    } else {
        if(isEmpty()){
            front = 0;
            rear = 0;
        } else if(rear == MAX - 1 && front != 0){
            rear = 0;
        } else {
            rear = (rear + 1) % MAX;
        }
        queue[rear] = data;
        printf("Element inserted!!!\n");
    }
}

int dequeue(){
    if(isEmpty()){
        printf("Underflow error\n");
        return -1;
    }
    int element = queue[front];
    if(front == rear){
        front = -1;
        rear = -1;
    } else if(front == MAX - 1){
        front = 0;
    } else {
        front = front + 1;
    }
    printf("Element removed!!!\n");
    return element;
}

void peek(){
    if(isEmpty()){
        printf("Queue is empty\n");
    } else {
        printf("Front element is: %d\n", queue[front]);
    }
}

void display(){
    if(isEmpty()){
        printf("Queue is empty\n");
        return;
    }
    printf("Queue elements: ");
    if(rear >= front){
        for(int i = front; i <= rear; i++)
            printf("%d ", queue[i]);
    } else {
        for(int i = front; i < MAX; i++)
            printf("%d ", queue[i]);
        for(int i = 0; i <= rear; i++)
            printf("%d ", queue[i]);
    }
    printf("\n");
}
int main(){
    int choice, value;
    while(1){
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. Peek\n");
        printf("4. Display\n");
        printf("5. Exitn\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
                scanf("%d",&value);
                enqueue(value);
                break;
            case 2:
                dequeue();
                break;
            case 3:
                peek();
                break;
            case 4:
                display();
                break;
            case 5:
                return -1;
                break;
        }

    }
}
