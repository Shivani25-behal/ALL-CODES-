#include <math.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <assert.h>
#include <limits.h>
#include <stdbool.h>
struct Node{
    int data;
    struct Node* next;
};
struct Node* head=NULL;
struct Node* createNode(int data){
    struct Node* temp=(struct Node*)malloc(sizeof(struct Node));
    temp->data=data;
    temp->next=NULL;
    return temp;
}

int main() {
    int n,val;
    scanf("%d",&n);
   struct Node* tail = NULL;
    int stack[n], top = -1;
    for(int i=0; i<n; i++){
        scanf("%d",&val);
        struct Node* newNode = createNode(val);
        if(head == NULL)
            head = newNode;
        else
            tail->next = newNode;
        stack[++top]= val;
        tail = newNode;
    }
    int flag = 0;
    struct Node* temp = head;
    for(int i= top; i>=0;i--){
        if(stack[i]!=temp->data){
            flag = 1;
            break;
        }
        temp = temp->next;
    }
    if(flag == 0)
        printf("Palindrome : ");
    else
        printf("Not Palindrome : ");
    for(int i = top; i>=0; i--){
        printf("%d ",stack[i]);
    }
     return 0;
}
