
#include<stdio.h>
#include<stdlib.h>
#define max 1000
int tree[max], index=0;
void initTree(){
    for (int i=0; i<max; i++){
        tree[i]=-1;
    }
}
void insert(int val){
    if(index<max){
        tree[index++]=val;
        printf("Node inserted in tree!!!\n");
    }
    else
        printf("Tree is full!!!\n");
}
void levelOrder(){
    if(index==0)
        printf("Tree is empty!!!\n");
    else{
        for(int i=0; i<index; i++){
            if(tree[i]!=-1)
                printf("%d ", tree[i]);
        }
    }
}
